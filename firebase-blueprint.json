{
  "entities": {
    "warranty": {
      "title": "Warranty Record",
      "description": "Details of a product warranty for a specific vehicle.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "vehicleVin": { "type": "string" },
        "vehicleModel": { "type": "string" },
        "installationDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "productName": { "type": "string" },
        "installerName": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Expired", "Void"] }
      },
      "required": ["customerName", "vehicleVin", "installationDate", "expiryDate", "productName", "status"]
    },
    "inquiry": {
      "title": "Contact Inquiry",
      "description": "Details of a contact form submission.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/warranties/{warrantyId}": {
      "schema": "warranty",
      "description": "Collection of all warranty records."
    },
    "/inquiries/{inquiryId}": {
      "schema": "inquiry",
      "description": "Collection of all contact form inquiries."
    }
  }
}
